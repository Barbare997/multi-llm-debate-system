# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Backup keys (used automatically when quota/rate limit is hit; up to 20 slots total)
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=


# Google Gemini — https://aistudio.google.com/apikey
# Primary key (GEMINI_API_KEY is accepted as an alias for the first slot)
GOOGLE_API_KEY=
# GEMINI_API_KEY=
# Backup keys (used automatically when quota/rate limit is hit; up to 20 slots total)
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
GOOGLE_API_KEY_5=

# Set GEMINI_DISABLED=1 to skip Gemini and use OpenAI fallback immediately
# GEMINI_DISABLED=0
GEMINI_FALLBACK_MODEL=gpt-4o-mini

# Groq — https://console.groq.com/keys
GROQ_API_KEY=
# Backup keys (used automatically when quota/rate limit is hit; up to 20 slots total)
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=

# Set GROQ_DISABLED=1 to skip Groq and use OpenAI fallback immediately
# GROQ_DISABLED=0
GROQ_FALLBACK_MODEL=gpt-4o-mini

OPENAI_MODEL_SOLVER_MINI=gpt-4o-mini
OPENAI_MODEL_SOLVER_STRONG=gpt-4o
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# Plain-text parser repair uses OpenAI when a stage response fails parsing
# STRUCTURE_REPAIR_DISABLED=1

# Stage 0.5 hybrid judge: score = VOTE_WEIGHT * ballots + CONF_WEIGHT * judge self-confidence
# ROLE_JUDGE_VOTE_WEIGHT=1.0
# ROLE_JUDGE_CONF_WEIGHT=1.0
